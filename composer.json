{
    "name": "capell-app/html-cache",
    "description": "Static HTML cache, dependency indexing, and cache administration for Capell.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "capell-app/frontend": "^4.0",
        "laravel/framework": "^11.44.2|^12.0|^13.0",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Capell\\HtmlCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\HtmlCache\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\HtmlCache\\Providers\\HtmlCacheServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "homepage": "https://github.com/capell-app/html-cache",
    "keywords": [
        "capell",
        "cms",
        "laravel",
        "cache",
        "frontend"
    ],
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/html-cache"
    }
}
